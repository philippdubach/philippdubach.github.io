{{- $base := .Site.BaseURL | strings.TrimRight "/" -}}
{
  "linkset": [
    {
      "anchor": "{{ $base }}/",
      "service-doc": [
        { "href": "{{ $base }}/llms.txt", "type": "text/plain", "title": "LLM discovery summary" },
        { "href": "{{ $base }}/llms-full.txt", "type": "text/plain", "title": "LLM discovery full content" }
      ],
      "alternate": [
        { "href": "{{ $base }}/feed/index.xml", "type": "application/rss+xml", "title": "RSS feed" },
        { "href": "{{ $base }}/feed.json", "type": "application/feed+json", "title": "JSON Feed" }
      ],
      "items": [
        { "href": "{{ $base }}/api/posts.json", "type": "application/json", "title": "Posts API" }
      ],
      "sitemap": [
        { "href": "{{ $base }}/sitemap.xml", "type": "application/xml", "title": "Sitemap" }
      ]
    }
  ]
}
